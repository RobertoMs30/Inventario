@page "{id:int}"
@model InventarioWeb.Pages.ImprimirOCModel
@{
    Layout = null;
    var o = Model.Orden!;
    var lineas = Model.Lineas;
    decimal totalSinIva = lineas.Sum(l => l.ImporteTotal);
    decimal iva = Math.Round(totalSinIva * 0.16m, 2);
    decimal totalConIva = totalSinIva + iva;
    // Asegurar mínimo 6 filas en tabla
    int minFilas = Math.Max(6, lineas.Count);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Orden de Compra No. @o.Oc</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }

        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 11px;
            background: #fff;
            color: #000;
            padding: 10px 14px;
        }

        /* ── Barra de acciones (solo pantalla) ── */
        .btn-bar { display:flex; gap:10px; align-items:center; margin-bottom:14px; }
        .btn-imprimir {
            background: #1e3a6e; color: #fff; border: none;
            padding: 8px 20px; border-radius: 6px; font-size: 13px;
            cursor: pointer; display:flex; align-items:center; gap:6px;
        }
        .btn-imprimir:hover { background: #162d55; }
        .btn-volver {
            background: #f0f0f0; color: #333; border: 1px solid #ccc;
            padding: 8px 16px; border-radius: 6px; font-size: 13px;
            text-decoration: none; display:flex; align-items:center; gap:6px;
        }
        @@media print { .btn-bar { display: none !important; } }

        /* ── Documento ── */
        .oc-doc {
            width: 100%;
            max-width: 960px;
            margin: 0 auto;
            border: 1px solid #000;
        }

        /* ── Sección 1: Header ── */
        .sec-header {
            display: grid;
            grid-template-columns: 220px 1fr 220px;
            border-bottom: 1px solid #000;
        }
        .hdr-logo {
            padding: 6px 10px;
            display: flex; flex-direction: column; justify-content: center;
            border-right: 1px solid #000;
        }
        .hdr-logo img { width: 110px; margin-bottom: 4px; }
        .hdr-logo .company-name {
            font-size: 7px; font-weight: bold; color: #1a3a6e;
            text-transform: uppercase; line-height: 1.3;
        }
        .hdr-center {
            display: flex; flex-direction: column;
            border-right: 1px solid #000;
        }
        .hdr-title {
            text-align: center;
            font-size: 20px; font-weight: bold;
            padding: 8px 0 4px;
            letter-spacing: 2px;
        }
        .folio-row {
            display: grid;
            grid-template-columns: 60px 60px 70px 1fr;
            border-top: 1px solid #000;
        }
        .folio-cell {
            border-right: 1px solid #000;
            padding: 3px 5px;
            text-align: center;
        }
        .folio-cell:last-child { border-right: none; }
        .folio-cell .folio-label {
            font-size: 8px; font-weight: bold; text-transform: uppercase;
            color: #444; border-bottom: 1px solid #ccc; margin-bottom: 2px;
        }
        .folio-cell .folio-val { font-size: 12px; font-weight: bold; }
        .folio-num {
            font-size: 16px; font-weight: bold; text-align: center; padding: 4px;
        }
        .folio-note { font-size: 7.5px; color: #555; text-align: center; }
        .hdr-info {
            padding: 6px 10px;
            font-size: 10px; line-height: 1.7;
        }
        .hdr-info .lbl { font-weight: bold; }

        /* ── Sección 2: Proveedor / Facturar / Consignar ── */
        .sec-prov {
            display: grid;
            grid-template-columns: 180px 1fr 200px;
            border-bottom: 1px solid #000;
        }
        .prov-col { padding: 5px 8px; border-right: 1px solid #000; font-size: 10px; line-height: 1.65; }
        .prov-col:last-child { border-right: none; }
        .prov-col .lbl { font-weight: bold; font-size: 9.5px; }

        /* ── Sección 3: Lab / Pago / Fecha entrega ── */
        .sec-lab {
            display: grid;
            grid-template-columns: 140px 1fr 220px;
            border-bottom: 1px solid #000;
            min-height: 36px;
        }
        .lab-col { padding: 4px 8px; border-right: 1px solid #000; font-size: 8px; display:flex; align-items:flex-start; flex-direction:column; }
        .lab-col:last-child { border-right: none; }
        .lab-col .lbl { font-weight: bold; font-size: 7.5px; }

        /* ── Tabla de artículos ── */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            border-bottom: 1px solid #000;
        }
        .items-table th {
            background: #1e3a6e;
            color: #fff;
            font-size: 9px;
            font-weight: bold;
            text-transform: uppercase;
            text-align: center;
            padding: 5px 4px;
            border: 1px solid #1e3a6e;
        }
        .items-table th.th-desc { text-align: left; padding-left: 6px; }
        .items-table td {
            border: 1px solid #888;
            padding: 4px 5px;
            font-size: 10px;
            vertical-align: middle;
        }
        .items-table td.td-center { text-align: center; }
        .items-table td.td-right  { text-align: right; }
        .items-table td.td-money  { text-align: right; font-weight: bold; }
        .items-table tr.tr-total-dlls td {
            border-top: 2px solid #000;
            background: #f9f9f9;
        }
        .total-dlls-label {
            color: #c00; font-weight: bold; font-size: 8px; text-transform: uppercase;
        }
        /* Filas vacías más delgadas */
        .items-table tr.empty-row td { height: 18px; }

        /* ── Sección 4: Footer ── */
        .sec-footer {
            display: grid;
            grid-template-columns: 1fr 200px;
            border-top: 1px solid #000;
        }
        .footer-sigs {
            padding: 5px 8px;
            border-right: 1px solid #000;
        }
        .footer-sigs .sig-row {
            display: flex; gap: 0; align-items: flex-end; margin-bottom: 2px;
        }
        .sig-box {
            flex: 1;
            text-align: center;
            border-bottom: 1px solid #000;
            padding-bottom: 12px;
            margin: 0 6px;
        }
        .sig-box .sig-name { font-weight: bold; font-size: 8px; }
        .sig-box .sig-role { font-size: 7px; color: #444; margin-top: 1px; }
        .footer-accept {
            font-size: 7px; margin-top: 6px; color: #333;
            padding: 0 6px;
        }
        .footer-accept .accept-title { font-weight: bold; font-size: 7px; }
        .footer-totals {
            padding: 5px 8px;
        }
        .total-row {
            display: flex; justify-content: space-between;
            align-items: center; padding: 2px 0;
            border-bottom: 1px solid #ddd; font-size: 8.5px;
        }
        .total-row:last-child { border-bottom: none; }
        .total-row .t-label { font-weight: bold; font-size: 8px; }
        .total-row .t-val {
            font-family: monospace; font-weight: bold; font-size: 9px;
            min-width: 80px; text-align: right;
            border: 1px solid #000; padding: 2px 5px;
        }
        .total-row.highlight { background: #f0f0f0; }

        /* ── Celdas editables en tabla ── */
        .cell-edit {
            cursor: text;
            outline: none;
            min-width: 20px;
        }
        .cell-edit:hover { background: #fffbe6; }
        .cell-edit:focus { background: #fff9c4; outline: 2px solid #f59e0b; }
        @@media print {
            .cell-edit { cursor: default; background: transparent !important; outline: none !important; }
        }

        /* ── Totales editables ── */
        .t-val.editable {
            cursor: text;
            outline: none;
            transition: background .15s;
        }
        .t-val.editable:hover { background: #fffbe6; }
        .t-val.editable:focus { background: #fff9c4; outline: 2px solid #f59e0b; }
        @@media print { .t-val.editable { cursor: default; background: transparent !important; outline: none !important; } }

        /* ── Sección 5: Firma proveedor ── */
        .sec-sigs {
            display: grid;
            grid-template-columns: 1fr 1fr 2fr 1fr;
            border-top: 1px solid #000;
            min-height: 55px;
        }
        .sig-cell {
            border-right: 1px solid #000;
            padding: 6px 8px;
            display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
        }
        .sig-cell:last-child { border-right: none; }
        .sig-cell .sig-label {
            font-size: 7.5px; font-weight: bold; text-align: center;
            border-top: 1px solid #000; width: 100%; text-align: center; padding-top: 2px; margin-top: 4px;
        }
        .sig-cell .prov-name { font-weight: bold; font-size: 8.5px; text-align: center; }
    </style>
</head>
<body>

<!-- Barra de acciones -->
<div class="btn-bar">
    <button class="btn-imprimir" onclick="window.print()">
        🖨️ Imprimir
    </button>
    <a class="btn-volver" href="/OrdenesCompra">← Volver</a>
</div>

<div class="oc-doc">

    <!-- ══ HEADER ══ -->
    <div class="sec-header">
        <!-- Logo -->
        <div class="hdr-logo">
            <div class="company-name">Nombre de tu Empresa, S.A. de C.V.</div>
        </div>

        <!-- Centro: título + folio -->
        <div class="hdr-center">
            <div class="hdr-title">ORDEN DE COMPRA</div>
            <div class="folio-row">
                <div class="folio-cell">
                    <div class="folio-label">DIA</div>
                    <div class="folio-val">@o.Fecha.Day.ToString("00")</div>
                </div>
                <div class="folio-cell">
                    <div class="folio-label">MES</div>
                    <div class="folio-val">@o.Fecha.Month.ToString("00")</div>
                </div>
                <div class="folio-cell">
                    <div class="folio-label">AÑO</div>
                    <div class="folio-val">@o.Fecha.Year</div>
                </div>
                <div class="folio-cell">
                    <div class="folio-label">ORIGEN / DESTINO &nbsp;&nbsp;&nbsp; No. FOLIO</div>
                    <div class="folio-num">No. @o.Oc</div>
                    <div class="folio-note">ESTE NÚMERO DEBERÁ APARECER EN SU REMISIÓN, FACTURA O CORRESPONDENCIA.</div>
                </div>
            </div>
        </div>

        <!-- Derecha: info OC -->
        <div class="hdr-info">
            <div><span class="lbl">CLIENTE :</span> @(string.IsNullOrEmpty(o.Cliente) ? "TU EMPRESA" : o.Cliente)</div>
            <div><span class="lbl">O.C. :</span> No. @o.Oc</div>
            <div style="margin-top:2px;"><span class="lbl">PROYECTO :</span> @o.Proyecto</div>
        </div>
    </div>

    <!-- ══ PROVEEDOR / FACTURAR / CONSIGNAR ══ -->
    <div class="sec-prov">
        <div class="prov-col">
            <div class="lbl">PROVEEDOR:</div>
            <div style="font-weight:bold;">@o.Proveedor</div>
            <div style="margin-top:4px;"><span class="lbl">CONTACTO: </span>@o.Contacto</div>
            <div style="margin-top:2px;"><span class="lbl">TEL. </span>@o.Telefono</div>
            <div style="margin-top:2px;"><span class="lbl">EMAIL: </span>@o.Email</div>
        </div>
        <div class="prov-col">
            <div><span class="lbl">FACTURAR A:</span> TU EMPRESA, S.A. DE C.V.</div>
            <div style="margin-top:2px;">Calle Ejemplo No. 123, COL. EJEMPLO</div>
            <div>CIUDAD, ESTADO CP 00000</div>
            <div style="margin-top:4px;">R.F.C.: XXX-000000-XX0 &nbsp;&nbsp; TEL. 00 00 00000000</div>
        </div>
        <div class="prov-col">
            <div class="lbl">CONSIGNAR A:</div>
            <div style="font-weight:bold;">@o.Cliente</div>
            <div style="margin-top:4px;">
                <span class="lbl">UBICACIÓN: </span>
                @o.Calle@(!string.IsNullOrEmpty(o.NumeroExt) ? " No. " + o.NumeroExt : "")@(!string.IsNullOrEmpty(o.Colonia) ? ", COL. " + o.Colonia : "")@(!string.IsNullOrEmpty(o.Cp) ? ", C.P. " + o.Cp : "")
            </div>
        </div>
    </div>

    <!-- ══ LAB / PAGO / FECHA ENTREGA ══ -->
    <div class="sec-lab">
        <div class="lab-col">
            <div class="lbl">LAB:</div>
            <div style="font-size:9px;">0</div>
        </div>
        <div class="lab-col">
            <div class="lbl">PAGO : TRANSFERENCIA – TARJETA – DEPÓSITO</div>
        </div>
        <div class="lab-col" style="text-align:right;">
            <div class="lbl">FECHA DE ENTREGA</div>
            <div class="lbl">DEL PROVEEDOR:</div>
            <div style="font-size:9px; margin-top:2px;">inmediato</div>
        </div>
    </div>

    <!-- ══ TABLA DE ARTÍCULOS ══ -->
    <table class="items-table">
        <thead>
            <tr>
                <th style="width:46px;">PARTIDA</th>
                <th style="width:64px;">NÚMERO DE<br />ARTÍCULOS</th>
                <th style="width:72px;">NÚMERO DE<br />REQUISICIÓN</th>
                <th class="th-desc">DESCRIPCIÓN</th>
                <th style="width:62px;">CANTIDAD</th>
                <th style="width:54px;">TIPO DE<br />UNIDAD</th>
                <th style="width:88px;">PRECIO UNITARIO</th>
                <th style="width:90px;">IMPORTE TOTAL</th>
            </tr>
        </thead>
        <tbody id="itemsTbody">
            @for (int i = 0; i < minFilas; i++)
            {
                if (i < lineas.Count)
                {
                    var l = lineas[i];
                    decimal imp = l.ImporteTotal == 0 && l.Cantidad != 0
                                  ? l.Cantidad * l.PrecioUnitario
                                  : l.ImporteTotal;
                    <tr class="item-row">
                        <td class="td-center">@(i + 1)</td>
                        <td class="td-center">@l.NoArticulo</td>
                        <td class="td-center">@o.NumRequisicion</td>
                        <td>@l.Descripcion</td>
                        <td class="td-right cell-edit" contenteditable="true" data-type="cant">@l.Cantidad.ToString("0.00##")</td>
                        <td class="td-center">@l.TipoUnidad</td>
                        <td class="td-money cell-edit" contenteditable="true" data-type="pu">@l.PrecioUnitario.ToString("0.00##")</td>
                        <td class="td-money cell-imp">$ @imp.ToString("0.00##")</td>
                    </tr>
                }
                else
                {
                    <tr class="empty-row">
                        <td class="td-center">@(i + 1)</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td class="cell-edit" contenteditable="true" data-type="cant"></td>
                        <td></td>
                        <td class="td-money cell-edit" contenteditable="true" data-type="pu"></td>
                        <td class="td-money cell-imp">$ -</td>
                    </tr>
                }
            }
            <tr class="empty-row"><td colspan="8"></td></tr>
            <tr class="empty-row"><td colspan="8"></td></tr>
        </tbody>
    </table>

    <!-- ══ FOOTER: Firmas + Totales ══ -->
    <div class="sec-footer">
        <!-- Firmas -->
        <div class="footer-sigs">
            <div class="sig-row">
                <div class="sig-box">
                    <div class="sig-name">@o.Elaboro</div>
                    <div class="sig-role">COMPRADOR</div>
                </div>
                <div class="sig-box">
                    <div class="sig-name">@o.Reviso</div>
                    <div class="sig-role">REVISÓ</div>
                </div>
                <div class="sig-box">
                    <div class="sig-name">@o.Aprobo</div>
                    <div class="sig-role">APROBÓ</div>
                </div>
                <div class="sig-box" style="flex:2;">
                    <div style="font-size:6.5px;text-align:center;color:#555;">
                        ACEPTAMOS EL CONTENIDO Y LAS CONDICIONES DE ESTA ORDEN DE COMPRA
                    </div>
                    <div class="sig-role">PROVEEDOR</div>
                </div>
            </div>
            <div class="footer-accept" style="margin-top:4px;">
                (NO SE TRAMITARÁ SU FACTURA SI NO SE ADJUNTA ESTA ORDEN DE COMPRA)
            </div>
        </div>

        <!-- Totales editables -->
        <div class="footer-totals">
            <div class="total-row">
                <div class="t-label">TOTAL SIN IVA =</div>
                <div class="t-val editable" contenteditable="true" id="valSinIva">$ @totalSinIva.ToString("N2")</div>
            </div>
            <div class="total-row">
                <div class="t-label">DESCUENTO =</div>
                <div class="t-val editable" contenteditable="true" id="valDescuento">$ 0.00</div>
            </div>
            <div class="total-row">
                <div class="t-label">A FAVOR</div>
                <div class="t-val editable" contenteditable="true" id="valAFavor">&nbsp;</div>
            </div>
            <div class="total-row">
                <div class="t-label">IVA =</div>
                <div class="t-val editable" contenteditable="true" id="valIva">$ @iva.ToString("N2")</div>
            </div>
            <div class="total-row highlight">
                <div class="t-label">TOTAL CON IVA =</div>
                <div class="t-val editable" contenteditable="true" id="valConIva">$ @totalConIva.ToString("N2")</div>
            </div>
        </div>
    </div>

    <!-- ══ FIRMAS FINALES ══ -->
    <div class="sec-sigs">
        <div class="sig-cell">
            <div class="prov-name">&nbsp;</div>
            <div class="sig-label">COMPRADOR</div>
        </div>
        <div class="sig-cell">
            <div class="prov-name">&nbsp;</div>
            <div class="sig-label">REVISÓ</div>
        </div>
        <div class="sig-cell">
            <div class="prov-name">@o.Proveedor</div>
            <div class="sig-label">PROVEEDOR</div>
        </div>
        <div class="sig-cell">
            <div class="prov-name">&nbsp;</div>
            <div class="sig-label">PROVEEDOR</div>
        </div>
    </div>

</div><!-- /oc-doc -->

<script>
    function parseNum(el) {
        return parseFloat((el.innerText || '').replace(/[^0-9.\-]/g, '')) || 0;
    }
    function fmtMoney(n) {
        // Mostrar hasta 4 decimales, sin ceros finales innecesarios (mínimo 2)
        const decimals = (n % 1 === 0) ? 2 :
            Math.max(2, (n.toString().split('.')[1] || '').replace(/0+$/, '').length);
        const maxDec = Math.min(decimals, 4);
        return '$ ' + n.toLocaleString('es-MX', {minimumFractionDigits: maxDec, maximumFractionDigits: 4});
    }

    // ── Recalcular fila ──────────────────────────────────────
    function recalcFila(row) {
        const cant  = parseFloat((row.querySelector('[data-type="cant"]')?.innerText  || '').replace(/[^0-9.\-]/g,'')) || 0;
        const pu    = parseFloat((row.querySelector('[data-type="pu"]')?.innerText    || '').replace(/[^0-9.\-]/g,'')) || 0;
        const imp   = row.querySelector('.cell-imp');
        if (imp) imp.innerText = cant > 0 || pu > 0 ? fmtMoney(cant * pu) : '$ -';
    }

    // ── Recalcular totales ───────────────────────────────────
    function recalcTotales() {
        let suma = 0;
        document.querySelectorAll('#itemsTbody .item-row .cell-imp').forEach(td => {
            suma += parseFloat((td.innerText || '').replace(/[^0-9.\-]/g,'')) || 0;
        });
        const descuento = parseNum(document.getElementById('valDescuento'));
        const base = suma - descuento;
        const iva = Math.round(base * 0.16 * 100) / 100;
        document.getElementById('valSinIva').innerText  = fmtMoney(suma);
        document.getElementById('valIva').innerText     = fmtMoney(iva);
        document.getElementById('valConIva').innerText  = fmtMoney(base + iva);
    }

    // ── Eventos en celdas de tabla ───────────────────────────
    document.querySelectorAll('#itemsTbody .cell-edit').forEach(td => {
        td.addEventListener('input', () => {
            const row = td.closest('tr');
            recalcFila(row);
            recalcTotales();
        });
    });

    // ── Eventos en totales del footer ────────────────────────
    const sinIva = document.getElementById('valSinIva');
    const valDescuento = document.getElementById('valDescuento');
    const valIva = document.getElementById('valIva');
    const conIva = document.getElementById('valConIva');

    // Al cambiar SIN IVA o DESCUENTO se recalcula el IVA (16% sobre la base) y el total
    function recalcDesdeBase() {
        const base = parseNum(sinIva) - parseNum(valDescuento);
        const iva = Math.round(base * 0.16 * 100) / 100;
        valIva.innerText = fmtMoney(iva);
        conIva.innerText = fmtMoney(base + iva);
    }
    // Al editar el IVA manualmente solo se recalcula el total con la base ya descontada
    function recalcConIva() {
        const base = parseNum(sinIva) - parseNum(valDescuento);
        conIva.innerText = fmtMoney(base + parseNum(valIva));
    }
    sinIva.addEventListener('input', recalcDesdeBase);
    valDescuento.addEventListener('input', recalcDesdeBase);
    valIva.addEventListener('input', recalcConIva);

    // ── Seleccionar todo al enfocar ──────────────────────────
    document.querySelectorAll('.cell-edit, .t-val.editable').forEach(el => {
        el.addEventListener('focus', () => {
            const range = document.createRange();
            range.selectNodeContents(el);
            const sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(range);
        });
    });

    // ── Calcular importes al cargar (por si hay cant*pu que no coincide) ──
    document.querySelectorAll('#itemsTbody .item-row').forEach(row => recalcFila(row));
    recalcTotales();
</script>
</body>
</html>
