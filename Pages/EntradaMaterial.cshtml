})();

// Autocomplete Proyecto — scope global para oninput
let _acPrDrop = null, _acPrTimer = null;
function acProyectoEntrada(inp) {
    clearTimeout(_acPrTimer);
    if (_acPrDrop) { _acPrDrop.remove(); _acPrDrop = null; }
    const q = inp.value.trim();
    if (q.length < 1) return;
    _acPrTimer = setTimeout(() => {
        fetch('?handler=SugProyecto&q=' + encodeURIComponent(q))
            .then(r => r.json())
            .then(list => {
                if (_acPrDrop) { _acPrDrop.remove(); _acPrDrop = null; }
                if (!list.length) return;
                const rect = inp.getBoundingClientRect();
                _acPrDrop = document.createElement('div');
                _acPrDrop.className = 'ac-salida-dropdown';
                _acPrDrop.style.cssText = `position:fixed;top:${rect.bottom}px;left:${rect.left}px;min-width:${rect.width}px;z-index:9999;`;
                list.forEach(item => {
                    const d = document.createElement('div');
                    d.className = 'ac-salida-item';
                    d.style.cssText = 'display:flex;gap:12px;align-items:baseline;';
                    const spanNum = document.createElement('span');
                    spanNum.textContent = item.num;
                    spanNum.style.cssText = 'min-width:60px;font-weight:600;flex-shrink:0;';
                    const spanNombre = document.createElement('span');
                    spanNombre.textContent = item.nombre;
                    spanNombre.style.cssText = 'color:#6b7280;font-size:.85em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
                    d.appendChild(spanNum);
                    d.appendChild(spanNombre);
                    d.addEventListener('mousedown', e => {
                        e.preventDefault();
                        inp.value = item.num;
                        _acPrDrop.remove(); _acPrDrop = null;
                    });
                    _acPrDrop.appendChild(d);
                });
                document.body.appendChild(_acPrDrop);
            });
    }, 250);
}
document.addEventListener('click', e => {
    const inp = document.getElementById('inputProyectoEntrada');
    if (_acPrDrop && inp && !inp.contains(e.target)) { _acPrDrop.remove(); _acPrDrop = null; }
});

// ── Selección de entradas para imprimir ──
function actualizarBotonEntrada() {
    const checked = document.querySelectorAll('.chk-entrada:checked');
    const todos = document.querySelectorAll('.chk-entrada');
    const chkTodos = document.getElementById('chkTodosEntrada');
    if (chkTodos) {
        if (checked.length === 0)               chkTodos.indeterminate = false, chkTodos.checked = false;
        else if (checked.length === todos.length) chkTodos.indeterminate = false, chkTodos.checked = true;
        else                                     chkTodos.indeterminate = true;
    }

    const btn = document.getElementById('btnImprimirEntradasSel');
    if (btn) {
        btn.disabled = checked.length === 0;
        const countEl = btn.querySelector('.sel-count-entradas');
        if (countEl) countEl.textContent = checked.length ? ` (${checked.length})` : '';
    }
}

function toggleTodosEntrada(chkAll) {
    document.querySelectorAll('.chk-entrada').forEach(c => c.checked = chkAll.checked);
    actualizarBotonEntrada();
}

function imprimirEntradasSeleccionadas() {
    const ids = Array.from(document.querySelectorAll('.chk-entrada:checked'))
        .map(c => c.dataset.id)
        .filter(Boolean);
    if (ids.length === 0) return;
    window.open('/ImprimirEntradas?ids=' + ids.join(','), '_blank');
}

// ── Historial mode toggle ──
function setHistMode(mode) {
    const isDev = mode === 'devolucion';
    document.getElementById('panelHistorialEntrada').style.display    = isDev ? 'none'  : 'block';
    document.getElementById('panelHistorialDevolucion').style.display = isDev ? 'block' : 'none';
    document.getElementById('btnHistEntrada').classList.toggle('active',    !isDev);
    document.getElementById('btnHistDevolucion').classList.toggle('active',  isDev);
    document.getElementById('histBadge').textContent = isDev
        ? '@Model.TotalRecordsDev registros'
        : '@Model.TotalRecords registros';
}
setHistMode('@(Model.HistMode == "devolucion" ? "devolucion" : "entrada")');

// ── Form mode toggle ──
function setFormMode(mode) {
    const isDevolucion = mode === 'devolucion';
    document.getElementById('panelEntrada').style.display    = isDevolucion ? 'none'  : 'block';
    document.getElementById('panelDevolucion').style.display = isDevolucion ? 'block' : 'none';
    document.getElementById('navBtnEntrada').classList.toggle('active',    !isDevolucion);
    document.getElementById('navBtnDevolucion').classList.toggle('active',  isDevolucion);
}
setFormMode('@(Model.ShowDevolucion ? "devolucion" : "entrada")');

// ── Devolución form autocomplete ──
(function () {
    function debounce(fn, ms) { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); }; }
    function escHtml(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // Simple text autocomplete (for filtros like Devuelve, Proyecto)
    function makeSimpleAc(inputId, handler) {
        const input = document.getElementById(inputId);
        if (!input) return;
        let dropdown = null, activeIdx = -1, results = [];

        function position() {
            if (!dropdown) return;
            const rect = input.getBoundingClientRect();
            const w = Math.max(rect.width, 200);
            let left = rect.left;
            if (left + w > window.innerWidth - 8) left = Math.max(8, window.innerWidth - w - 8);
            dropdown.style.width = w + 'px'; dropdown.style.left = left + 'px';
            const spaceBelow = window.innerHeight - rect.bottom - 4;
            if (spaceBelow >= 80) { dropdown.style.top = (rect.bottom + 4) + 'px'; dropdown.style.bottom = 'auto'; dropdown.style.maxHeight = Math.min(220, spaceBelow) + 'px'; }
            else { dropdown.style.top = 'auto'; dropdown.style.bottom = (window.innerHeight - rect.top + 4) + 'px'; dropdown.style.maxHeight = Math.min(220, rect.top - 4) + 'px'; }
        }
        function close() { if (dropdown) { dropdown.remove(); dropdown = null; } activeIdx = -1; }
        function setActive(idx) {
            if (!dropdown) return;
            dropdown.querySelectorAll('.ac-salida-item').forEach(el => el.classList.remove('active'));
            if (idx >= 0) { const el = dropdown.querySelectorAll('.ac-salida-item')[idx]; if (el) { el.classList.add('active'); el.scrollIntoView({ block: 'nearest' }); } }
            activeIdx = idx;
        }
        function show(items) {
            close(); results = items; activeIdx = -1;
            dropdown = document.createElement('div'); dropdown.className = 'ac-salida-dropdown';
            if (!items.length) { dropdown.innerHTML = '<div class="ac-salida-item" style="color:var(--text-muted)">Sin resultados</div>'; }
            else items.forEach((val, i) => {
                const div = document.createElement('div'); div.className = 'ac-salida-item';
                div.innerHTML = `<div class="ac-salida-codfab">${escHtml(val)}</div>`;
                div.addEventListener('mousedown', e => { e.preventDefault(); input.value = val; close(); });
                dropdown.appendChild(div);
            });
            document.body.appendChild(dropdown); position();
        }
        window.addEventListener('scroll', () => { if (dropdown) position(); }, { passive: true });
        window.addEventListener('resize', () => { if (dropdown) position(); }, { passive: true });
        const doSearch = debounce(async (q) => {
            if (q.length < 1) { close(); return; }
            try { show(await (await fetch(`/EntradaMaterial?handler=${handler}&q=${encodeURIComponent(q)}`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })).json()); }
            catch { close(); }
        }, 250);
        input.addEventListener('input',  () => doSearch(input.value.trim()));
        input.addEventListener('blur',   () => setTimeout(close, 160));
        input.addEventListener('keydown', (e) => {
            if (!dropdown) return;
            const items = dropdown.querySelectorAll('.ac-salida-item');
            if      (e.key === 'ArrowDown')              { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
            else if (e.key === 'ArrowUp')                { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
            else if (e.key === 'Enter' && activeIdx >= 0){ e.preventDefault(); const r = results[activeIdx]; if (r) { input.value = r; close(); } }
            else if (e.key === 'Escape')                 { close(); }
        });
    }

    makeSimpleAc('devInputDevuelve',    'SugDevuelve');
    makeSimpleAc('devInputProyecto',    'SugProyecto');

    // Catalog autocomplete for devolución form (reuses BuscarCatalogo handler)
    (function () {
        const triggerEl   = document.getElementById('devInputCodDisplay');
        const hidCodFab   = document.getElementById('devInputCodFab');
        const hidCodInt   = document.getElementById('devInputCodInt');
        const descEl      = document.getElementById('devInputDescripcion');
        const umEl        = document.getElementById('devInputUm');
        if (!triggerEl) return;
        let dropdown = null, activeIdx = -1, results = [];

        function position() {
            if (!dropdown) return;
            const rect = triggerEl.getBoundingClientRect();
            const w = Math.max(rect.width, 360);
            let left = rect.left;
            if (left + w > window.innerWidth - 8) left = Math.max(8, window.innerWidth - w - 8);
            dropdown.style.width = w + 'px'; dropdown.style.left = left + 'px';
            const spaceBelow = window.innerHeight - rect.bottom - 4;
            if (spaceBelow >= 120) { dropdown.style.top = (rect.bottom + 4) + 'px'; dropdown.style.bottom = 'auto'; dropdown.style.maxHeight = Math.min(300, spaceBelow) + 'px'; }
            else { dropdown.style.top = 'auto'; dropdown.style.bottom = (window.innerHeight - rect.top + 4) + 'px'; dropdown.style.maxHeight = Math.min(300, rect.top - 4) + 'px'; }
        }
        function close() { if (dropdown) { dropdown.remove(); dropdown = null; } activeIdx = -1; }
        function select(item) {
            if (!item) return;
            hidCodFab.value = item.codFab || '';
            hidCodInt.value = item.codInt || item.codFab || '';
            triggerEl.value = item.codFab + (item.codInt ? ' (' + item.codInt + ')' : '');
            if (descEl) descEl.value = item.descripcion || '';
            if (umEl)   umEl.value   = item.um || '';
            close();
            document.getElementById('DevForm_Cantidad')?.focus();
        }
        function show(items) {
            close(); results = items; activeIdx = -1;
            dropdown = document.createElement('div'); dropdown.className = 'ac-entrada-dropdown';
            if (!items.length) { dropdown.innerHTML = '<div class="ac-entrada-empty"><i class="bi bi-search me-1"></i>Sin resultados</div>'; }
            else items.forEach((item, i) => {
                const div = document.createElement('div'); div.className = 'ac-entrada-item';
                const exist = parseFloat(item.existencia) || 0;
                const existColor = exist > 10 ? 'var(--accent-green)' : exist > 0 ? '#f59e0b' : 'var(--accent-red)';
                div.innerHTML = `<div class="ac-entrada-codfab"><i class="bi bi-upc me-1"></i>${escHtml(item.codFab)}${item.codInt ? `<span style="color:var(--text-muted);font-size:.78rem;margin-left:.4rem;">(${escHtml(item.codInt)})</span>` : ''}</div><div class="ac-entrada-desc">${escHtml(item.descripcion)}</div><div class="ac-entrada-meta">${item.um ? `<span><i class="bi bi-rulers"></i>${escHtml(item.um)}</span>` : ''}<span style="color:${existColor};"><i class="bi bi-box-seam"></i>Exist: ${exist.toFixed(0)}</span></div>`;
                div.addEventListener('mousedown', e => { e.preventDefault(); select(items[i]); });
                dropdown.appendChild(div);
            });
            document.body.appendChild(dropdown); position();
        }
        window.addEventListener('scroll', () => { if (dropdown) position(); }, { passive: true });
        window.addEventListener('resize', () => { if (dropdown) position(); }, { passive: true });
        const doSearch = debounce(async (q) => {
            if (q.length < 1) { close(); return; }
            close();
            dropdown = document.createElement('div'); dropdown.className = 'ac-entrada-dropdown';
            dropdown.innerHTML = '<div class="ac-entrada-loading"><i class="bi bi-hourglass-split me-1"></i>Buscando…</div>';
            document.body.appendChild(dropdown); position();
            try { show(await (await fetch(`/EntradaMaterial?handler=BuscarCatalogo&q=${encodeURIComponent(q)}`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })).json()); }
            catch { close(); }
        }, 250);
        triggerEl.addEventListener('input',  () => doSearch(triggerEl.value.trim()));
        triggerEl.addEventListener('blur',   () => setTimeout(close, 160));
        triggerEl.addEventListener('keydown', (e) => {
            if (!dropdown) return;
            const items = dropdown.querySelectorAll('.ac-entrada-item');
            if      (e.key === 'ArrowDown')              { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
            else if (e.key === 'ArrowUp')                { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
            else if (e.key === 'Enter' && activeIdx >= 0){ e.preventDefault(); select(results[activeIdx]); }
            else if (e.key === 'Escape')                 { close(); }
            function setActive(idx) {
                dropdown.querySelectorAll('.ac-entrada-item').forEach(el => el.classList.remove('active'));
                if (idx >= 0 && idx < items.length) { items[idx].classList.add('active'); items[idx].scrollIntoView({ block: 'nearest' }); }
                activeIdx = idx;
            }
        });
    })();
})();
