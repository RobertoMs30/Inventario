@page "{cotizacionId:int}"
@model EntradaDesdeCotizacionModel
@{
    ViewData["Title"] = "Entrada desde Cotización";
    int ok = int.TryParse(Request.Query["ok"], out var okVal) ? okVal : 0;
}

<style>
    .edc-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.5rem 1rem;
    }
    .edc-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .edc-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: .5rem;
    }
    .edc-title i { color: var(--accent-primary); }

    /* Info cotización */
    .cot-info-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: .6rem 1.2rem;
        margin-bottom: 1.5rem;
    }
    @@media (max-width: 860px) { .cot-info-grid { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 480px) { .cot-info-grid { grid-template-columns: 1fr; } }
    .cot-info-item { display: flex; flex-direction: column; gap: .1rem; }
    .cot-info-label {
        font-size: .7rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .4px;
        font-weight: 600;
    }
    .cot-info-value { font-size: .92rem; color: var(--text-primary); font-weight: 500; }

    /* Tabla de ítems */
    .edc-table-wrapper {
        overflow-x: auto;
        border-radius: 8px;
        border: 1px solid #c8d8f0;
        margin-bottom: 1.25rem;
    }
    .edc-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1100px;
    }
    .edc-table thead th {
        background: #1e3a6e;
        color: #a8c0e0;
        font-size: .67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        padding: 9px 10px;
        white-space: nowrap;
    }
    .edc-table tbody tr { border-bottom: 1px solid #e4ecf9; transition: background .1s; }
    .edc-table tbody tr:nth-child(even) { background: #eef3ff; }
    .edc-table tbody tr:nth-child(odd)  { background: #fff; }
    .edc-table tbody tr.row-selected { background: #dbeafe !important; outline: 1.5px solid #93c5fd; outline-offset: -1px; }
    .edc-table tbody tr.row-disabled { opacity: .45; }
    .edc-table td { padding: 6px 9px; vertical-align: middle; font-size: .85rem; color: #1b2a45; }

    .edc-table input[type=text],
    .edc-table input[type=number],
    .edc-table input[type=date] {
        width: 100%;
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: 5px;
        padding: .28rem .4rem;
        font-size: .82rem;
        outline: none;
        box-sizing: border-box;
        transition: border-color .2s;
    }
    .edc-table input:focus { border-color: var(--accent-primary); box-shadow: 0 0 0 2px rgba(30,58,110,.12); }
    .edc-table input:disabled { opacity: .45; cursor: not-allowed; }

    /* Checkbox personalizado */
    .check-cell { width: 36px; text-align: center; }
    .chk-item { width: 17px; height: 17px; cursor: pointer; accent-color: var(--accent-primary); }

    /* Badge material nuevo */
    .badge-nuevo {
        display: none;
        font-size: .68rem;
        background: rgba(251,146,60,.15);
        color: #ea7c2e;
        border: 1px solid rgba(251,146,60,.4);
        border-radius: 4px;
        padding: .1rem .35rem;
        white-space: nowrap;
    }
    .badge-nuevo.visible { display: inline-block; }

    /* Campos extra para material nuevo */
    .extra-nuevo { display: none; }
    .extra-nuevo.visible { display: table-row; }
    .extra-nuevo td {
        background: rgba(251,146,60,.06) !important;
        border-top: 1px dashed rgba(251,146,60,.4);
        padding: 6px 9px 8px;
    }
    .extra-nuevo-grid {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        align-items: flex-end;
    }
    .extra-nuevo-grid label { font-size: .72rem; color: var(--text-muted); display: block; margin-bottom: .15rem; }
    .extra-nuevo-grid input, .extra-nuevo-grid select {
        background: var(--bg-primary);
        border: 1px solid rgba(251,146,60,.5);
        color: var(--text-primary);
        border-radius: 5px;
        padding: .28rem .4rem;
        font-size: .82rem;
        outline: none;
        box-sizing: border-box;
    }
    .extra-nuevo-grid input:focus, .extra-nuevo-grid select:focus {
        border-color: #ea7c2e;
        box-shadow: 0 0 0 2px rgba(251,146,60,.2);
    }

    /* Autocomplete */
    .ac-dropdown {
        position: fixed;
        background: var(--bg-secondary);
        border: 1px solid var(--accent-primary);
        border-radius: 6px;
        box-shadow: 0 8px 32px rgba(0,0,0,.7);
        z-index: 99999;
        overflow-y: auto;
        min-width: 340px;
    }
    .ac-item { padding: .45rem .7rem; cursor: pointer; border-bottom: 1px solid rgba(0,0,0,.04); transition: background .12s; }
    .ac-item:last-child { border-bottom: none; }
    .ac-item:hover, .ac-item.ac-active { background: rgba(30,58,110,.13); }
    .ac-main { font-size: .82rem; font-weight: 600; color: var(--text-primary); }
    .ac-sub  { font-size: .72rem; color: var(--text-muted); margin-top: .1rem; display: flex; gap: .5rem; flex-wrap: wrap; }
    .ac-empty, .ac-loading { padding: .55rem .7rem; color: var(--text-muted); font-size: .8rem; text-align: center; }

    /* Sección global */
    .global-fields {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }
    @@media (max-width: 680px) { .global-fields { grid-template-columns: 1fr 1fr; } }
    .field-label { font-size: .78rem; color: var(--text-muted); margin-bottom: .25rem; }

    .actions-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
        margin-top: .5rem;
    }
    .sel-count {
        font-size: .85rem;
        color: var(--text-muted);
    }
    .sel-count strong { color: var(--accent-primary); }
</style>

<div class="edc-container">

    <div class="edc-header">
        <div class="edc-title">
            <i class="bi bi-box-arrow-in-down"></i>
            Entrada desde Cotización
        </div>
        <a href="/VerCotizacion/@Model.CotizacionId" style="text-decoration:none;">
            <span class="btn-outline-dark-custom"
                  style="padding:.4rem .85rem;font-size:.85rem;display:inline-flex;align-items:center;gap:.35rem;">
                <i class="bi bi-arrow-left"></i> Volver
            </span>
        </a>
    </div>

    @if (ok > 0)
    {
        <div class="alert-dark-success" style="padding:.75rem 1rem;border-radius:8px;margin-bottom:1.25rem;">
            <i class="bi bi-check-circle-fill me-2"></i>
            Se registraron <strong>@ok</strong> entrada@(ok == 1 ? "" : "s") de material correctamente.
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-dark-error" style="padding:.75rem 1rem;border-radius:8px;margin-bottom:1.25rem;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @Model.ErrorMessage
        </div>
    }

    <!-- Datos de la cotización -->
    <div class="card-dark" style="padding:1.1rem 1.25rem;margin-bottom:1.25rem;">
        <div class="card-dark-header" style="margin-bottom:.75rem;padding-bottom:.5rem;border-bottom:1px solid var(--border-color);font-size:.88rem;font-weight:600;">
            <i class="bi bi-file-earmark-text me-2" style="color:var(--accent-primary);"></i>
            Cotización de referencia
        </div>
        <div class="cot-info-grid">
            <div class="cot-info-item">
                <span class="cot-info-label"><i class="bi bi-hash me-1"></i>Folio</span>
                <span class="cot-info-value" style="font-family:monospace;color:var(--accent-primary);">
                    @Model.Cotizacion!.Folio
                </span>
            </div>
            <div class="cot-info-item">
                <span class="cot-info-label"><i class="bi bi-calendar3 me-1"></i>Fecha</span>
                <span class="cot-info-value">@Model.Cotizacion.Fecha.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="cot-info-item">
                <span class="cot-info-label"><i class="bi bi-building me-1"></i>Cliente</span>
                <span class="cot-info-value">@Model.Cotizacion.Cliente</span>
            </div>
            <div class="cot-info-item">
                <span class="cot-info-label"><i class="bi bi-diagram-3 me-1"></i>Proyecto</span>
                <span class="cot-info-value">@Model.Cotizacion.Proyecto</span>
            </div>
        </div>
    </div>

    <form method="post" id="formEntrada">
        @Html.AntiForgeryToken()

        <!-- Campos globales -->
        <div class="card-dark" style="padding:1.1rem 1.25rem;margin-bottom:1.25rem;">
            <div class="card-dark-header" style="margin-bottom:.75rem;padding-bottom:.5rem;border-bottom:1px solid var(--border-color);font-size:.88rem;font-weight:600;">
                <i class="bi bi-sliders me-2" style="color:var(--accent-primary);"></i>
                Datos comunes para todos los ítems
                <span style="font-size:.75rem;color:var(--text-muted);font-weight:400;margin-left:.5rem;">
                    (puedes sobreescribir por ítem)
                </span>
            </div>
            <div class="global-fields">
                <div>
                    <div class="field-label">Fecha de compra <span style="color:var(--accent-red);">*</span></div>
                    <input type="date" name="fechaGlobal" id="fechaGlobal"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>
                <div>
                    <div class="field-label">No. Orden de Compra</div>
                    <input type="text" name="noPoGlobal" id="noPoGlobal"
                           class="form-control" placeholder="Opcional — aplica a todos" maxlength="100" />
                </div>
                <div>
                    <div class="field-label">FAC / Factura</div>
                    <input type="text" name="facGlobal" id="facGlobal"
                           class="form-control" placeholder="Opcional — aplica a todos" maxlength="100" />
                </div>
            </div>
        </div>

        <!-- Tabla de ítems -->
        <div class="card-dark" style="padding:1.1rem 1.25rem;">
            <div class="card-dark-header" style="margin-bottom:.75rem;padding-bottom:.5rem;border-bottom:1px solid var(--border-color);font-size:.88rem;font-weight:600;display:flex;justify-content:space-between;align-items:center;">
                <span>
                    <i class="bi bi-list-check me-2" style="color:var(--accent-primary);"></i>
                    Selecciona los ítems que llegaron
                </span>
                <span class="sel-count">Seleccionados: <strong id="lblCount">0</strong> de @Model.Items.Count</span>
            </div>

            <div class="edc-table-wrapper">
                <table class="edc-table" id="edcTable">
                    <thead>
                        <tr>
                            <th class="check-cell">
                                <input type="checkbox" id="chkAll" title="Seleccionar todos" class="chk-item"
                                       onchange="toggleAll(this)" />
                            </th>
                            <th style="width:42px;">Ítem</th>
                            <th style="min-width:180px;">Descripción</th>
                            <th style="width:75px;">Cantidad</th>
                            <th style="width:60px;">Unidad</th>
                            <th style="min-width:160px;">Cod. Fab. <span style="color:var(--accent-red)">*</span></th>
                            <th style="min-width:130px;">Proveedor</th>
                            <th style="width:130px;">Fecha compra</th>
                            <th style="width:100px;">No. PO</th>
                            <th style="width:90px;">FAC</th>
                            <th style="width:80px;">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (int i = 0; i < Model.Items.Count; i++)
                    {
                        var item = Model.Items[i];
                        <tr id="row-@i" class="row-disabled">
                            <!-- Checkbox -->
                            <td class="check-cell">
                                <input type="checkbox" class="chk-item row-chk"
                                       data-idx="@i"
                                       onchange="toggleRow(@i, this.checked)"
                                       name="items[@i].Seleccionado" value="true" />
                            </td>
                            <!-- Ítem -->
                            <td style="text-align:center;font-family:monospace;color:var(--text-muted);font-size:.78rem;">
                                @item.NoItem
                            </td>
                            <!-- Descripción -->
                            <td>
                                <input type="text" name="items[@i].Descripcion"
                                       value="@item.Descripcion"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- Cantidad -->
                            <td>
                                <input type="number" name="items[@i].Cantidad"
                                       value="@item.Cantidad.ToString("0.##")"
                                       min="0.01" step="0.01"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- Unidad -->
                            <td>
                                <input type="text" name="items[@i].Unidad"
                                       value="@item.Unidad"
                                       maxlength="30"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- Cod. Fab (autocomplete) -->
                            <td style="position:relative;">
                                <input type="text" name="items[@i].CodFab"
                                       id="codFab-@i"
                                       placeholder="Buscar o escribir…"
                                       autocomplete="off"
                                       data-row="@i"
                                       class="row-input cod-fab-input" disabled />
                            </td>
                            <!-- Proveedor -->
                            <td>
                                <input type="text" name="items[@i].Proveedor"
                                       value="@item.Proveedor"
                                       maxlength="200"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- Fecha compra individual -->
                            <td>
                                <input type="date" name="items[@i].FechaCompra"
                                       id="fecha-@i"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- No. PO individual -->
                            <td>
                                <input type="text" name="items[@i].NoPo"
                                       maxlength="100" placeholder="—"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- FAC individual -->
                            <td>
                                <input type="text" name="items[@i].Fac"
                                       maxlength="100" placeholder="—"
                                       class="row-input" data-row="@i" disabled />
                            </td>
                            <!-- Estado: badge nuevo/existente -->
                            <td>
                                <span id="badge-@i" class="badge-nuevo">Nuevo</span>
                            </td>
                            <!-- Hidden: datos de la cotización para fallback -->
                            <input type="hidden" name="items[@i].PrecioUnitarioCot" value="@item.PrecioUnitarioCot" />
                            <input type="hidden" name="items[@i].MonedaCot" value="@item.MonedaCot" />
                        </tr>
                        <!-- Fila extra para campos de material nuevo -->
                        <tr id="extra-@i" class="extra-nuevo">
                            <td colspan="11">
                                <div class="extra-nuevo-grid">
                                    <div>
                                        <label>Partida</label>
                                        <input type="text" name="items[@i].Partida"
                                               id="partida-@i"
                                               placeholder="GENERAL"
                                               style="width:110px;" />
                                    </div>
                                    <div>
                                        <label>Precio Unitario</label>
                                        <input type="number" name="items[@i].Pu"
                                               id="pu-@i"
                                               value="@item.PrecioUnitarioCot.ToString("0.##")"
                                               min="0" step="0.01"
                                               style="width:110px;" />
                                    </div>
                                    <div>
                                        <label>Moneda</label>
                                        @{
                                            var isMxn = item.MonedaCot == "MXN";
                                            var isUsd = item.MonedaCot == "USD";
                                        }
                                        <select name="items[@i].Moneda" id="moneda-@i" style="width:80px;">
                                            <option value="MXN" selected="@isMxn">MXN</option>
                                            <option value="USD" selected="@isUsd">USD</option>
                                        </select>
                                    </div>
                                    <div style="font-size:.75rem;color:#ea7c2e;align-self:flex-end;padding-bottom:.3rem;">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Material nuevo — se creará en el catálogo
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="actions-bar">
                <div class="sel-count">
                    <i class="bi bi-info-circle me-1"></i>
                    Primer Cod. Int. disponible:
                    <strong style="font-family:monospace;">@Model.PrimerCodInt</strong>
                    (se asignan automáticamente)
                </div>
                <button type="submit" class="btn-accent" style="padding:.55rem 1.5rem;font-size:.95rem;" id="btnGuardar">
                    <i class="bi bi-box-arrow-in-down me-1"></i> Registrar entradas
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
    // ── Estado global ─────────────────────────────────────────
    let selCount = 0;
    const totalRows = @Model.Items.Count;

    // ── Seleccionar/deseleccionar fila ────────────────────────
    function toggleRow(idx, checked) {
        const row    = document.getElementById('row-'   + idx);
        const inputs = row.querySelectorAll('.row-input');

        if (checked) {
            row.classList.remove('row-disabled');
            row.classList.add('row-selected');
            inputs.forEach(inp => inp.disabled = false);
            selCount++;
            // Poner fecha global si el campo de fecha está vacío
            const fechaInp = document.getElementById('fecha-' + idx);
            if (fechaInp && !fechaInp.value)
                fechaInp.value = document.getElementById('fechaGlobal').value;
        } else {
            row.classList.add('row-disabled');
            row.classList.remove('row-selected');
            inputs.forEach(inp => inp.disabled = true);
            selCount--;
            // Ocultar badge y fila extra si se deselecciona
            document.getElementById('badge-' + idx).classList.remove('visible');
            document.getElementById('extra-' + idx).classList.remove('visible');
        }

        document.getElementById('lblCount').textContent = selCount;
        document.getElementById('chkAll').indeterminate = selCount > 0 && selCount < totalRows;
        document.getElementById('chkAll').checked = selCount === totalRows;
    }

    function toggleAll(chk) {
        document.querySelectorAll('.row-chk').forEach(c => {
            const idx = parseInt(c.dataset.idx);
            if (c.checked !== chk.checked) {
                c.checked = chk.checked;
                toggleRow(idx, chk.checked);
            }
        });
    }

    // ── Autocomplete Cod. Fab. ────────────────────────────────
    function debounce(fn, ms) {
        let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
    }

    function escH(s) {
        return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function initCodFabAc(rowIdx) {
        const input = document.getElementById('codFab-' + rowIdx);
        if (!input) return;

        let dropdown = null;
        let lastResults = [];
        let activeIdx = -1;

        function positionDropdown() {
            if (!dropdown) return;
            const rect = input.getBoundingClientRect();
            const w = Math.max(rect.width, 340);
            dropdown.style.width = w + 'px';
            let left = rect.left;
            if (left + w > window.innerWidth - 8) left = Math.max(8, window.innerWidth - w - 8);
            dropdown.style.left = left + 'px';
            const below = window.innerHeight - rect.bottom - 4;
            const above = rect.top - 4;
            if (below >= 100) {
                dropdown.style.top       = (rect.bottom + 4) + 'px';
                dropdown.style.bottom    = 'auto';
                dropdown.style.maxHeight = Math.min(280, below) + 'px';
            } else {
                dropdown.style.top       = 'auto';
                dropdown.style.bottom    = (window.innerHeight - rect.top + 4) + 'px';
                dropdown.style.maxHeight = Math.min(280, above) + 'px';
            }
        }

        function closeDropdown() {
            if (dropdown) { dropdown.remove(); dropdown = null; }
            activeIdx = -1;
        }

        function setActive(idx) {
            if (!dropdown) return;
            const items = dropdown.querySelectorAll('.ac-item');
            items.forEach(el => el.classList.remove('ac-active'));
            if (idx >= 0 && idx < items.length) {
                items[idx].classList.add('ac-active');
                items[idx].scrollIntoView({ block: 'nearest' });
            }
            activeIdx = idx;
        }

        function applyResult(item) {
            input.value = item.codFab;
            closeDropdown();

            const row = document.getElementById('row-' + rowIdx);
            // Pre-llenar proveedor si el campo está vacío
            const provInp = row.querySelector('input[name*="Proveedor"]');
            if (provInp && !provInp.value && item.proveedor) provInp.value = item.proveedor;

            // Badge y fila extra para material nuevo
            const badge = document.getElementById('badge-' + rowIdx);
            const extra = document.getElementById('extra-' + rowIdx);
            if (!item.existe) {
                badge.textContent = 'Nuevo';
                badge.classList.add('visible');
                extra.classList.add('visible');
                // Pre-llenar PU/Moneda desde catálogo si hay
                if (item.pu > 0) {
                    const puInp = document.getElementById('pu-' + rowIdx);
                    if (puInp && !puInp.dataset.edited) puInp.value = item.pu;
                }
                const monSel = document.getElementById('moneda-' + rowIdx);
                if (monSel && item.moneda) monSel.value = item.moneda;
                if (item.partida) {
                    const partInp = document.getElementById('partida-' + rowIdx);
                    if (partInp && !partInp.value) partInp.value = item.partida;
                }
            } else {
                badge.textContent = 'Existente';
                badge.style.background = 'rgba(30,58,110,.12)';
                badge.style.color = 'var(--accent-primary)';
                badge.style.borderColor = 'rgba(30,58,110,.3)';
                badge.classList.add('visible');
                extra.classList.remove('visible');
            }
        }

        function showDropdown(items) {
            closeDropdown();
            lastResults = items; activeIdx = -1;
            dropdown = document.createElement('div');
            dropdown.className = 'ac-dropdown';
            dropdown.style.cssText = 'position:fixed;z-index:99999;overflow-y:auto;';
            if (items.length === 0) {
                // Sin resultados: ofrecer crear con este cod_fab
                const val = input.value.trim();
                dropdown.innerHTML = `
                    <div class="ac-item" style="color:#ea7c2e;">
                        <div class="ac-main"><i class="bi bi-plus-circle me-1"></i>Usar "<strong>${escH(val)}</strong>" como nuevo material</div>
                        <div class="ac-sub">Se creará en el catálogo al guardar</div>
                    </div>`;
                dropdown.querySelector('.ac-item').addEventListener('mousedown', e => {
                    e.preventDefault();
                    applyResult({ codFab: val, existe: false, proveedor: '', pu: 0, moneda: 'MXN', partida: '' });
                });
            } else {
                items.forEach((item, i) => {
                    const div = document.createElement('div');
                    div.className = 'ac-item';
                    div.innerHTML = `
                        <div class="ac-main">
                            <i class="bi bi-upc me-1" style="color:var(--accent-primary);font-size:.75rem;"></i>
                            ${escH(item.codFab)}
                            ${!item.existe ? '<span style="font-size:.68rem;color:#ea7c2e;background:rgba(251,146,60,.1);border:1px solid rgba(251,146,60,.3);border-radius:3px;padding:.05rem .3rem;margin-left:.3rem;">Nuevo</span>' : ''}
                        </div>
                        <div class="ac-sub">
                            <span>${escH(item.descripcion)}</span>
                            ${item.proveedor ? `<span><i class="bi bi-building"></i>${escH(item.proveedor)}</span>` : ''}
                            ${item.pu > 0 ? `<span><i class="bi bi-cash"></i>${parseFloat(item.pu).toFixed(2)} ${escH(item.moneda)}</span>` : ''}
                        </div>`;
                    div.addEventListener('mousedown', e => { e.preventDefault(); applyResult(item); });
                    dropdown.appendChild(div);
                });
            }
            document.body.appendChild(dropdown);
            positionDropdown();
        }

        const onReflow = () => { if (dropdown) positionDropdown(); };
        window.addEventListener('scroll', onReflow, { passive: true });
        window.addEventListener('resize', onReflow, { passive: true });

        const doSearch = debounce(async (q) => {
            if (q.length < 1) { closeDropdown(); return; }
            closeDropdown();
            dropdown = document.createElement('div');
            dropdown.className = 'ac-dropdown';
            dropdown.style.cssText = 'position:fixed;z-index:99999;overflow-y:auto;';
            dropdown.innerHTML = '<div class="ac-loading"><i class="bi bi-hourglass-split me-1"></i>Buscando…</div>';
            document.body.appendChild(dropdown);
            positionDropdown();
            try {
                const resp = await fetch(
                    `/EntradaDesdeCotizacion/@Model.CotizacionId?handler=BuscarCatalogo&q=${encodeURIComponent(q)}`,
                    { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!resp.ok) { closeDropdown(); return; }
                showDropdown(await resp.json());
            } catch { closeDropdown(); }
        }, 260);

        input.addEventListener('input', () => doSearch(input.value.trim()));
        input.addEventListener('keydown', e => {
            if (!dropdown) return;
            const items = dropdown.querySelectorAll('.ac-item');
            if      (e.key === 'ArrowDown')              { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
            else if (e.key === 'ArrowUp')                { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
            else if (e.key === 'Enter' && activeIdx >= 0){ e.preventDefault(); items[activeIdx].dispatchEvent(new MouseEvent('mousedown')); }
            else if (e.key === 'Escape')                 { closeDropdown(); }
        });
        input.addEventListener('blur', () => setTimeout(closeDropdown, 160));
    }

    // Inicializar autocomplete para todos los ítems
    document.addEventListener('DOMContentLoaded', () => {
        for (let i = 0; i < totalRows; i++) initCodFabAc(i);
    });

    // Validar antes de enviar
    document.getElementById('formEntrada').addEventListener('submit', e => {
        if (selCount === 0) {
            e.preventDefault();
            alert('Debes seleccionar al menos un ítem para dar entrada.');
            return;
        }
        // Verificar que todos los seleccionados tengan cod_fab
        let ok = true;
        document.querySelectorAll('.row-chk:checked').forEach(chk => {
            const idx = chk.dataset.idx;
            const cf  = document.getElementById('codFab-' + idx).value.trim();
            if (!cf) {
                alert(`El ítem de la fila ${parseInt(idx)+1} no tiene Cod. Fab. — es obligatorio.`);
                ok = false;
            }
        });
        if (!ok) e.preventDefault();
    });
</script>
}
