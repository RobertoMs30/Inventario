@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
    var hoy = DateTime.Now;
    string[] diasSemana = { "Domingo","Lunes","Martes","Miércoles","Jueves","Viernes","Sábado" };
    string[] meses = { "","Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre" };
    var fechaStr = $"{diasSemana[(int)hoy.DayOfWeek]} {hoy.Day} de {meses[hoy.Month]}, {hoy.Year}";
}

<div class="dashboard">

    <!-- ── Header ────────────────────────────────────────── -->
    <div class="dash-header">
        <div class="dash-header-left">
            <h1 class="dash-title">Dashboard</h1>
            <p class="dash-subtitle">Bienvenido al sistema de inventario TU EMPRESA</p>
        </div>
        <div class="dash-header-right">
            <i class="bi bi-calendar3"></i>
            <span>@fechaStr</span>
        </div>
    </div>

    <!-- ── KPI Cards ──────────────────────────────────────── -->
    <div class="kpi-row">

        <a href="/Catalogo" class="kpi-card kpi-card--navy">
            <div class="kpi-icon"><i class="bi bi-boxes"></i></div>
            <div class="kpi-body">
                <span class="kpi-value">@Model.TotalProductos</span>
                <span class="kpi-label">Productos en catálogo</span>
            </div>
        </a>

        <a href="/Catalogo" class="kpi-card @(Model.StockNegativo > 0 ? "kpi-card--red" : "kpi-card--rose")">
            <div class="kpi-icon">
                <i class="bi @(Model.StockNegativo > 0 ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
            </div>
            <div class="kpi-body">
                <span class="kpi-value">@Model.StockNegativo</span>
                <span class="kpi-label">Stock negativo</span>
            </div>
            @if (Model.StockNegativo > 0)
            {
                <span class="kpi-badge">Revisar</span>
            }
        </a>

        <a href="/EntradaMaterial" class="kpi-card kpi-card--blue">
            <div class="kpi-icon"><i class="bi bi-box-seam-fill"></i></div>
            <div class="kpi-body">
                <span class="kpi-value">@Model.EntradasMes</span>
                <span class="kpi-label">Entradas este mes</span>
            </div>
        </a>

        <a href="/SalidaMaterial" class="kpi-card kpi-card--yellow">
            <div class="kpi-icon"><i class="bi bi-box-arrow-up"></i></div>
            <div class="kpi-body">
                <span class="kpi-value">@Model.SalidasMes</span>
                <span class="kpi-label">Salidas este mes</span>
            </div>
        </a>

    </div>

    <!-- ── Cuerpo ─────────────────────────────────────────── -->
    <div class="dash-body">

        <!-- Accesos rápidos -->
        <div class="dash-section">
            <h2 class="section-title"><i class="bi bi-lightning-charge-fill"></i> Accesos rápidos</h2>
            <div class="quick-actions">

                <a href="/EntradaMaterial" class="qa-card qa-card--navy">
                    <div class="qa-icon"><i class="bi bi-plus-circle-fill"></i></div>
                    <div class="qa-text">
                        <span class="qa-name">Nueva entrada</span>
                        <span class="qa-desc">Registrar material recibido</span>
                    </div>
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>

                <a href="/SalidaMaterial" class="qa-card qa-card--yellow">
                    <div class="qa-icon"><i class="bi bi-box-arrow-up"></i></div>
                    <div class="qa-text">
                        <span class="qa-name">Nueva salida</span>
                        <span class="qa-desc">Registrar material enviado</span>
                    </div>
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>

                <a href="/NuevaCotizacion" class="qa-card qa-card--green">
                    <div class="qa-icon"><i class="bi bi-file-earmark-plus-fill"></i></div>
                    <div class="qa-text">
                        <span class="qa-name">Nueva cotización</span>
                        <span class="qa-desc">Crear cotización para cliente</span>
                    </div>
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>

                <a href="/Catalogo" class="qa-card qa-card--gray">
                    <div class="qa-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                    <div class="qa-text">
                        <span class="qa-name">Ver catálogo</span>
                        <span class="qa-desc">Consultar todos los productos</span>
                    </div>
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>

                <a href="/Cotizaciones" class="qa-card qa-card--gray">
                    <div class="qa-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
                    <div class="qa-text">
                        <span class="qa-name">Cotizaciones</span>
                        <span class="qa-desc">Ver historial de cotizaciones</span>
                    </div>
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>

                <a href="/Devolucion" class="qa-card qa-card--gray">
                    <div class="qa-icon"><i class="bi bi-arrow-return-left"></i></div>
                    <div class="qa-text">
                        <span class="qa-name">Devoluciones</span>
                        <span class="qa-desc">Registrar o ver devoluciones</span>
                    </div>
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>

            </div>
        </div>

        <!-- Actividad reciente -->
        <div class="dash-section">
            <h2 class="section-title"><i class="bi bi-clock-history"></i> Actividad reciente</h2>

            @if (Model.Actividad.Count == 0)
            {
                <div class="activity-empty">
                    <i class="bi bi-inbox"></i>
                    <span>Sin actividad reciente o base de datos no disponible</span>
                </div>
            }
            else
            {
                <div class="activity-list">
                    @foreach (var item in Model.Actividad)
                    {
                        var esEntrada = item.Tipo == "Entrada";
                        var diasAtras = (DateTime.Today - item.Fecha.Date).Days;
                        var fechaLabel = diasAtras == 0 ? "Hoy"
                                       : diasAtras == 1 ? "Ayer"
                                       : item.Fecha.ToString("dd MMM");

                        <div class="activity-item">
                            <div class="activity-dot activity-dot--@(esEntrada ? "entrada" : "salida")">
                                <i class="bi @(esEntrada ? "bi-arrow-down-circle-fill" : "bi-arrow-up-circle-fill")"></i>
                            </div>
                            <div class="activity-info">
                                <span class="activity-code">@item.CodFab</span>
                                <span class="activity-desc">@(item.Descripcion.Length > 45 ? item.Descripcion[..45] + "…" : item.Descripcion)</span>
                            </div>
                            <div class="activity-meta">
                                <span class="activity-badge activity-badge--@(esEntrada ? "entrada" : "salida")">@item.Tipo</span>
                                <span class="activity-date">@fechaLabel</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>

<style>
/* ── Layout ─────────────────────────────────────── */
.dashboard {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1100px;
}

/* ── Header ─────────────────────────────────────── */
.dash-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--border-color);
}

.dash-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 2px 0;
    letter-spacing: -0.02em;
}

.dash-subtitle {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 0;
}

.dash-header-right {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--text-dark);
    font-size: 0.82rem;
}

/* ── KPI Cards ──────────────────────────────────── */
.kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}

.kpi-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border-radius: 12px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
}

.kpi-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0);
    transition: background 0.2s;
}

.kpi-card:hover::after {
    background: rgba(255,255,255,0.08);
}

.kpi-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.kpi-card--navy  { background: var(--accent-primary); border-color: var(--accent-hover); }
.kpi-card--red   { background: var(--accent-red);     border-color: #7a2020; }
.kpi-card--green { background: var(--accent-green);   border-color: #1a4d34; }
.kpi-card--rose  { background: #7a3535;               border-color: #5c2020; }
.kpi-card--blue  { background: #1d4ed8;               border-color: #1e40af; }
.kpi-card--yellow{ background: var(--accent-yellow);  border-color: #8c5a1e; }

.kpi-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.kpi-icon i {
    font-size: 1.4rem;
    color: rgba(255,255,255,0.9);
}

.kpi-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.kpi-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    letter-spacing: -0.03em;
}

.kpi-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
}

.kpi-badge {
    position: absolute;
    top: 10px;
    right: 12px;
    background: rgba(255,255,255,0.2);
    color: #ffffff;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* ── Body ───────────────────────────────────────── */
.dash-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
}

.section-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.section-title i {
    font-size: 0.9rem;
    color: var(--accent-primary);
}

/* ── Quick Actions ──────────────────────────────── */
.quick-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.qa-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 10px;
    text-decoration: none;
    border: 1px solid var(--border-color);
    background: #ffffff;
    transition: all 0.18s ease;
    box-shadow: var(--shadow-sm);
}

.qa-card:hover {
    transform: translateX(3px);
    box-shadow: var(--shadow);
}

.qa-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1rem;
}

.qa-card--navy  .qa-icon { background: var(--accent-light);         color: var(--accent-primary); }
.qa-card--yellow .qa-icon{ background: rgba(184,118,42,.12);        color: var(--accent-yellow); }
.qa-card--green  .qa-icon{ background: rgba(39,104,69,.12);         color: var(--accent-green); }
.qa-card--gray   .qa-icon{ background: var(--bg-tertiary);          color: var(--text-muted); }

.qa-card--navy:hover  { border-color: var(--accent-primary); }
.qa-card--yellow:hover{ border-color: var(--accent-yellow); }
.qa-card--green:hover { border-color: var(--accent-green); }
.qa-card--gray:hover  { border-color: var(--border-light); }

.qa-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
}

.qa-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
}

.qa-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.qa-arrow {
    color: var(--text-darker);
    font-size: 0.75rem;
    transition: transform 0.18s;
}

.qa-card:hover .qa-arrow {
    transform: translateX(3px);
    color: var(--text-dark);
}

/* ── Activity ───────────────────────────────────── */
.activity-list {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
}

.activity-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid #f0f4fb;
    transition: background 0.12s;
}

.activity-item:last-child { border-bottom: none; }
.activity-item:hover { background: #f8fafd; }

.activity-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.9rem;
}

.activity-dot--entrada { background: rgba(39,104,69,.12);  color: var(--accent-green); }
.activity-dot--salida  { background: rgba(184,118,42,.12); color: var(--accent-yellow); }

.activity-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
}

.activity-code {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent-primary);
    font-family: 'Consolas', monospace;
}

.activity-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.activity-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    flex-shrink: 0;
}

.activity-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.activity-badge--entrada { background: rgba(39,104,69,.1);  color: var(--accent-green); }
.activity-badge--salida  { background: rgba(184,118,42,.1); color: var(--accent-yellow); }

.activity-date {
    font-size: 0.72rem;
    color: var(--text-dark);
}

.activity-empty {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 24px 20px;
    color: var(--text-dark);
    font-size: 0.85rem;
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 10px;
}

.activity-empty i { font-size: 1.3rem; }

/* ── Responsive ─────────────────────────────────── */
@@media (max-width: 900px) {
    .kpi-row  { grid-template-columns: repeat(2, 1fr); }
    .dash-body { grid-template-columns: 1fr; }
}

@@media (max-width: 540px) {
    .kpi-row { grid-template-columns: 1fr 1fr; }
    .dash-header { flex-direction: column; align-items: flex-start; gap: 6px; }
}
</style>
